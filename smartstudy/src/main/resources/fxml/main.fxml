<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.smartstudy.ui.controllers.MainController"
            stylesheets="@../css/styles.css">

    <top>
        <VBox alignment="CENTER" spacing="10" styleClass="header">
            <padding>
                <Insets top="20" right="20" bottom="10" left="20"/>
            </padding>
            <Label text="SmartStudy" styleClass="title">
                <font>
                    <Font name="Arial" size="32" weight="BOLD"/>
                </font>
            </Label>
            <Label text="Study Session Manager" styleClass="subtitle">
                <font>
                    <Font name="Arial" size="14"/>
                </font>
            </Label>
        </VBox>
    </top>

    <center>
        <TabPane xmlns="http://javafx.com/javafx" tabClosingPolicy="UNAVAILABLE" styleClass="main-tabs">

            <Tab text="Study Session">
                <VBox spacing="20" alignment="CENTER">
                    <padding>
                        <Insets top="30" right="20" bottom="20" left="20"/>
                    </padding>

                    <!-- Timer Display -->
                    <StackPane>
                        <VBox alignment="CENTER" spacing="20" styleClass="timer-container">
                            <Label fx:id="timerLabel" text="25:00" styleClass="timer-display"/>
                        </VBox>
                    </StackPane>

                    <!-- Timer Controls -->
                    <HBox spacing="15" alignment="CENTER">
                        <Button fx:id="startButton" text="Start" styleClass="btn-primary" onAction="#startTimer"
                                prefWidth="100"/>
                        <Button fx:id="pauseButton" text="Pause" styleClass="btn-secondary" onAction="#pauseTimer"
                                disable="true" prefWidth="100"/>
                        <Button fx:id="resetButton" text="Reset" styleClass="btn-secondary" onAction="#resetTimer"
                                disable="true" prefWidth="100"/>
                    </HBox>

                    <!-- Settings -->
                    <HBox spacing="20" alignment="CENTER">
                        <VBox spacing="5" alignment="CENTER">
                            <Label text="Subject" styleClass="field-label"/>
                            <ComboBox fx:id="subjectComboBox" promptText="Select Subject" prefWidth="180"/>
                        </VBox>
                        <VBox spacing="5" alignment="CENTER">
                            <Label text="Duration (min)" styleClass="field-label"/>
                            <Spinner fx:id="durationSpinner" prefWidth="100"/>
                        </VBox>
                    </HBox>

                    <!-- Notes -->
                    <VBox spacing="5" alignment="CENTER" prefWidth="500">
                        <Label text="Session Notes" styleClass="field-label"/>
                        <TextArea fx:id="notesTextArea" promptText="Write your notes here..."
                                  prefRowCount="4" prefWidth="500" wrapText="true"/>
                    </VBox>

                    <!-- Quick Stats -->
                    <HBox spacing="30" alignment="CENTER" styleClass="stats-bar">
                        <Label fx:id="todayStatsLabel" text="Today: 0 min"/>
                        <Label fx:id="weekStatsLabel" text="This Week: 0 min"/>
                        <Label fx:id="totalStatsLabel" text="Total: 0 sessions"/>
                    </HBox>
                </VBox>
            </Tab>

            <Tab text="Statistics">
                <HBox spacing="20" padding="20">
                    <!-- Chart Section -->
                    <VBox spacing="15" HBox.hgrow="ALWAYS">
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label text="Study Time Chart" styleClass="section-title"/>
                            <ComboBox fx:id="periodComboBox" prefWidth="120"/>
                            <Button text="Refresh" onAction="#refreshData" styleClass="btn-small"/>
                        </HBox>
                        <BarChart fx:id="statsChart" prefHeight="300" legendVisible="false">
                            <xAxis>
                                <CategoryAxis label="Date"/>
                            </xAxis>
                            <yAxis>
                                <javafx.scene.chart.NumberAxis label="Minutes"/>
                            </yAxis>
                        </BarChart>
                    </VBox>

                    <!-- Side Panel -->
                    <VBox spacing="15" prefWidth="280" styleClass="side-panel">
                        <Label text="Subject Breakdown" styleClass="section-title"/>
                        <ListView fx:id="subjectBreakdownList" prefHeight="150"/>

                        <Label text="AI Recommendations" styleClass="section-title"/>
                        <ListView fx:id="recommendationsList" prefHeight="200"/>
                    </VBox>
                </HBox>
            </Tab>
        </TabPane>
    </center>

    <bottom>
        <HBox alignment="CENTER" spacing="20" styleClass="footer">
            <padding>
                <Insets top="10" right="20" bottom="10" left="20"/>
            </padding>
            <Label text="SmartStudy v1.0 | BYOP College Project"/>
        </HBox>
    </bottom>
</BorderPane>
